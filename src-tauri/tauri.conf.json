{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Lector",
  "version": "1.0.0",
  "identifier": "com.simdad.lector",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:7860",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Lector",
        "width": 960,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:*"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "../server.py": "server.py",
      "../crypto.py": "crypto.py",
      "../library_store.py": "library_store.py",
      "../license_manager.py": "license_manager.py",
      "../text_parser.py": "text_parser.py",
      "../requirements.txt": "requirements.txt",
      "../launch.bat": "launch.bat",
      "../launch-silent.vbs": "launch-silent.vbs",
      "../static": "static",
      "../vendor": "vendor"
    },
    "licenseFile": "../LICENSE",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": {
        "sidecar": true
      }
    },
    "notification": {
      "all": true
    }
  }
}
